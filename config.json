{
  "speed_mode": "safe",
  "api": {
    "base_delay": 0.1,
    "max_delay": 1.0,
    "min_delay": 0.1,
    "retry_attempts": 3,
    "max_workers": 4
  },
  "data": {
    "max_cache_days": 7,
    "float_dtype": "float32",
    "data_download_period": {
      "1m": "7d",
      "1h": "730d",
      "1d": "max"
    },
    "enable_cache": true,
    "enable_finviz": true
