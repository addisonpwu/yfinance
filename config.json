    "bb_period": 20,
    "bb_std_dev": 2,
    "atr_period": 14,
    "ma_periods": [5, 10, 20, 50, 120, 200],
    "cmo_period": 14,
    "williams_r_period": 14,
    "stochastic_period": 14,
    "stochastic_smooth_period": 3,
    "volume_z_score_period": 20
