# Frontend Environment Variables
# All frontend env vars must be prefixed with VITE_ to be exposed to client code
# See: https://vite.dev/guide/env-and-mode

# API base URL for backend
# In development: http://localhost:8000 (FastAPI default port)
# In production: empty string (uses nginx proxy via same origin)
VITE_API_BASE=http://localhost:8000
