# ========================================
# 股票筛选系统 - 环境变量配置
# ========================================
# 说明：
# 1. 复制此文件为 .env
# 2. 填写实际的 API 密钥
# 3. 切勿将 .env 文件提交到版本控制
# ========================================

# ----------------
# AI API 配置
# ----------------
# iFlow API 密钥（用于 iFlow AI 股票分析）
IFLOW_API_KEY=your_iflow_api_key_here

# iFlow API 基础 URL（可选，默认值如下）
IFLOW_API_BASE_URL=https://api.iflow.com/v1

# NVIDIA NIM API 密钥（用于 NVIDIA AI 股票分析）
# 获取地址: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your_key_here

# Google Gemini API 密钥（用于 Gemini AI 股票分析）
# 获取地址: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------
# 数据源配置
# ----------------
# Finviz API 密钥（可选，增强数据获取能力）
# FINVIZ_API_KEY=your_finviz_api_key_here

# ----------------
# 日志级别
# ----------------
# 可选值: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ----------------
# 开发环境配置
# ----------------
# 开发模式（启用调试功能）
DEV_MODE=false

# ----------------
# 代理配置（可选）
# ----------------
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890